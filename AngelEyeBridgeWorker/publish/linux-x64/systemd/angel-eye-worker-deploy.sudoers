# Install as /etc/sudoers.d/angel-eye-worker-deploy with mode 0440.
# The deploy account receives no general shell or systemctl permission.
Defaults:angeldeploy !requiretty
angeldeploy ALL=(root) NOPASSWD: /usr/local/sbin/angel-eye-worker-deploy status
